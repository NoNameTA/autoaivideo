{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Chrome (CDP)",
  "properties": {
    "url": {
      "type": "string",
      "title": "URL mở",
      "description": "URL điều hướng. Có thể truyền qua inputs.url."
    },
    "wait_ms": {
      "type": "integer",
      "title": "Chờ tải (ms)",
      "default": 1500
    },
    "chrome_path": {
      "type": "string",
      "title": "Đường dẫn chrome.exe",
      "description": "Bỏ trống để tự dò."
    }
  },
  "required": []
}
